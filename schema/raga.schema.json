{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raga.schema.json",
  "title": "RagaJSON Schema",
  "description": "Machine-readable schema for describing ragas of Indian classical music.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Raga name."
    },
    "system": {
      "$ref": "./components/system_enum.json",
      "description": "Indian classical music system (Hindustani)."
    },
    "classification": {
      "$ref": "./components/hindustani_classification_enum.json",
      "description": "Raga classification."
    },
    "structure": {
      "type": "object",
      "description": "Structural parameters of the raga (notes, patterns, etc.).",
      "properties": {
        "aroha": {
          "type": "array",
          "items": { "$ref": "./components/hindustani_sargam_enum.json" },
          "description": "Ascending sequence of notes"
        },
        "avaroha": {
          "type": "array",
          "items": { "$ref": "./components/hindustani_sargam_enum.json" },
          "description": "Descending sequence of notes"
        },
        "svaras": {
          "type": "array",
          "items": { "$ref": "./components/hindustani_sargam_enum.json" },
          "description": "List of notes used"
        },
        "vadi": {
          "$ref": "./components/hindustani_sargam_enum.json",
          "description": "Vadi — principal (most prominent) note of the raga"
        },
        "samvadi": {
          "$ref": "./components/hindustani_sargam_enum.json",
          "description": "Samvadi — second most prominent note of the raga"
        },
        "pakad": {
          "type": "string",
          "description": "Pakad — characteristic melodic phrase of the raga"
        },
        "jaati": {
          "$ref": "./components/jaati_enum.json",
          "description": "Jaati — classification by number of notes (e.g., audav, shadav, sampurna, etc.)"
        },
        "varjit_svaras": {
          "type": "array",
          "items": { "$ref": "./components/hindustani_sargam_enum.json" },
          "description": "Varjit svaras — omitted notes"
        }
      },
      "additionalProperties": false
    },
    "performance": {
      "type": "object",
      "description": "Performance-related information (time, season, rasa, etc.).",
      "properties": {
        "form": {
          "type": "string",
          "description": "Performance form (khayal, dhrupad, etc., English only)"
        },
        "tempo": {
          "type": "string",
          "description": "Performance tempo (vilambit, madhya, drut, etc.)"
        },
        "time_of_day": {
          "oneOf": [
            {
              "$ref": "./components/time_of_day_enum.json"
            },
            {
              "type": "array",
              "items": {
                "$ref": "./components/time_of_day_enum.json"
              },
              "uniqueItems": true
            }
          ],
          "description": "Traditional time of day (Samay Chakra) for raga performance. String or array."
        },
        "season": {
          "$ref": "./components/season_enum.json",
          "description": "Traditional season for raga performance."
        },
        "rasa": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rasa": {
                "$ref": "./components/rasa_enum.json",
                "description": "Name of the rasa"
              },
              "weight": {
                "type": "number",
                "description": "Weight (intensity) of this rasa, from 0 to 1",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": ["rasa", "weight"],
            "additionalProperties": false
          },
          "description": "List of rasas with weights (intensity)"
        },
        "composers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Famous composers associated with the raga"
        },
        "notable_performers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Famous performers of the raga"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["name", "system"],
  "additionalProperties": false
}
